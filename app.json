{
  "expo": {
    "name": "Geo-Contextual App",
    "slug": "geo-app",
    "owner": "girasss",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.man1pekanbaru.geocontextual"
    },
    "android": {
      "package": "com.man1pekanbaru.geocontextual",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2F4F74"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#2F4F74"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikasi memerlukan akses ke galeri untuk memilih foto.",
          "cameraPermission": "Aplikasi memerlukan akses ke kamera untuk mengambil foto."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "da263c91-d477-4cde-8337-0af82de40310"
      }
    }
  }
}
