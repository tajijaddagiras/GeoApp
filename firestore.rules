rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin safely
    function isAdmin() {
      // Check if document exists FIRST to prevent evaluation errors when registering
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ===========================================
    // USERS COLLECTION
    // ===========================================
    match /users/{userId} {
      // User can read their own profile, admin can read all profiles
      allow read: if isOwner(userId) || isAdmin();
      
      // IMPORTANT: put (isAuthenticated() && request.auth.uid == userId) first!
      // This prevents unnecessary admin checks during normal signup
      allow create: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
      
      // Users can update their own data but CANNOT change their role. Admin can update everything.
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      
      // Only admin can delete users
      allow delete: if isAdmin();
    }
    
    // ===========================================
    // MATERI COLLECTION
    // ===========================================
    match /materi/{materiId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // ===========================================
    // SOAL COLLECTION
    // ===========================================
    match /soal/{soalId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // ===========================================
    // PROGRES COLLECTION
    // ===========================================
    match /progres/{progresId} {
      // User can read their own progress, admin can read all progress (for statistics)
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // User can create their own progress
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // User can update their own progress, but cannot change the userId
      allow update: if isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      
      allow delete: if isAdmin();
    }
    
    // ===========================================
    // JURNAL COLLECTION (Private)
    // ===========================================
    match /jurnal/{jurnalId} {
      // User can read their own jurnal, admin can read all jurnal if needed
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Ensure user cannot modify the userId of their existing journal
      allow update: if isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // ===========================================
    // DEFAULT: Deny all other access
    // ===========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
